# Vishwamitra — local LLM credentials
# Copy this file to .env and fill in your real values.
# .env is .gitignored and never pushed.

# OpenAI-compatible API endpoint (Groq, Fireworks, Together, HF, Cerebras, Ollama, ...)
API_BASE_URL=https://api.groq.com/openai/v1

# Model identifier as the provider expects it
MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct

# Bearer token / API key (variable is called HF_TOKEN to match the
# hackathon spec, but the value can be ANY provider's key — Groq, Fireworks, etc.)
HF_TOKEN=your_provider_api_key_here

# Optional — only needed if you launch via from_docker_image()
# LOCAL_IMAGE_NAME=vishwamitra:latest
